@{
    ViewData["Title"] = "FlowDesk";
}

<div style="text-align: center; padding: 1rem 2rem 3rem;">

    <span style="display: inline-block; background: #f4f4f5; border: 1px solid #e4e4e7; border-radius: 999px; padding: 4px 14px; font-size: 13px; color: #71717a; margin-bottom: 1.5rem;">
        Sistema de chamados corporativo
    </span>

    <h1 style="font-size: 3rem; font-weight: 600; color: #09090b; margin: 0 0 1rem; letter-spacing: -1px;">
        Gerencie seus tickets<br>com eficiência
    </h1>

    <p style="font-size: 1.1rem; color: #71717a; max-width: 480px; margin: 0 auto 2.5rem; line-height: 1.6;">
        FlowDesk centraliza suporte, tarefas e chamados em um só lugar. Simples, rápido e organizado.
    </p>

    <div style="display: flex; gap: 12px; justify-content: center; flex-wrap: wrap;">
        <a asp-controller="Usuario" asp-action="Login" class="fd-btn-primary"
           style="background: #09090b; color: #fff; padding: 10px 28px; border-radius: 8px; font-size: 15px; text-decoration: none;">
            Entrar
        </a>
        <a asp-controller="Usuario" asp-action="CriarConta" class="fd-btn-ghost"
           style="background: transparent; color: #09090b; border: 1px solid #d4d4d8; padding: 10px 28px; border-radius: 8px; font-size: 15px; text-decoration: none;">
            Criar conta
        </a>
    </div>
</div>

<hr style="border: none; border-top: 1px solid #f4f4f5; margin: 0 2rem 3rem;">

<div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(200px, 1fr)); gap: 16px; padding: 0 2rem 4rem;">

    <div class="fd-card" style="border: 1px solid #e4e4e7; border-radius: 12px; padding: 1.25rem;">
        <div style="font-size: 1.5rem; margin-bottom: 12px;">🎫</div>
        <h3 style="font-size: 15px; font-weight: 600; margin: 0 0 6px; color: #09090b;">Gestão de tickets</h3>
        <p style="font-size: 13px; color: #71717a; margin: 0; line-height: 1.5;">Crie, acompanhe e resolva chamados com prioridades e status em tempo real.</p>
    </div>

    <div class="fd-card" style="border: 1px solid #e4e4e7; border-radius: 12px; padding: 1.25rem;">
        <div style="font-size: 1.5rem; margin-bottom: 12px;">📊</div>
        <h3 style="font-size: 15px; font-weight: 600; margin: 0 0 6px; color: #09090b;">Dashboard</h3>
        <p style="font-size: 13px; color: #71717a; margin: 0; line-height: 1.5;">Visualize métricas e acompanhe o desempenho da sua equipe de suporte.</p>
    </div>

    <div class="fd-card" style="border: 1px solid #e4e4e7; border-radius: 12px; padding: 1.25rem;">
        <div style="font-size: 1.5rem; margin-bottom: 12px;">💬</div>
        <h3 style="font-size: 15px; font-weight: 600; margin: 0 0 6px; color: #09090b;">Comentários</h3>
        <p style="font-size: 13px; color: #71717a; margin: 0; line-height: 1.5;">Histórico completo de mensagens dentro de cada chamado.</p>
    </div>

    <div class="fd-card" style="border: 1px solid #e4e4e7; border-radius: 12px; padding: 1.25rem;">
        <div style="font-size: 1.5rem; margin-bottom: 12px;">🛡️</div>
        <h3 style="font-size: 15px; font-weight: 600; margin: 0 0 6px; color: #09090b;">Permissões</h3>
        <p style="font-size: 13px; color: #71717a; margin: 0; line-height: 1.5;">Controle de acesso por nível: admin, suporte e usuário comum.</p>
    </div>

</div>