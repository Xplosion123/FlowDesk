<!DOCTYPE html>
<html lang="pt-br">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - FlowDesk</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/FlowDesk.styles.css" asp-append-version="true" />
</head>
<body style="margin:0; padding:0;">
    <div style="display:flex;">
        @await Html.PartialAsync("_Sidebar")
        <div style="flex:1; display:flex; flex-direction:column;">
            <header style="height:56px; background:#111111; border-bottom:0.5px solid #27272a; display:flex; align-items:center; justify-content:space-between; padding:0 1.5rem;">
                <div style="display:flex; align-items:center; gap:10px;">
                    <span style="font-size:14px; font-weight:500; color:#fff;">Olá, @User.Identity.Name 👋</span>
                    @if (User.IsInRole("Admin"))
                    {
                        <span style="background:#1a2e1a; color:#1DB954; font-size:11px; padding:2px 8px; border-radius:999px; border:0.5px solid #1DB95430;">Administrador</span>
                    }
                </div>
                <div style="display:flex; align-items:center; gap:12px;">
                    <div style="background:#1a1a1a; border:0.5px solid #27272a; border-radius:999px; padding:5px 12px; font-size:12px; color:#a1a1aa; display:flex; align-items:center; gap:6px;">
                        🔔 <span>5</span>
                    </div>
                    <div style="width:30px; height:30px; border-radius:50%; background:#1DB954; display:flex; align-items:center; justify-content:center; font-size:11px; font-weight:500; color:#000;">
                        @User.Identity.Name[0].ToString().ToUpper()
                    </div>
                    <a asp-controller="Usuario" asp-action="Sair" style="color:#71717a; font-size:13px; text-decoration:none;">Sair</a>
                </div>
            </header>
            <div class="main">
                @RenderBody()
            </div>
        </div>
    </div>
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>