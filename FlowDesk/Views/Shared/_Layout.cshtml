<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - FlowDesk</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/FlowDesk.styles.css" asp-append-version="true" />
</head>
<body>
    <header style="background: #fff; height: 65px; display: flex; align-items: center; padding: 0 2rem; justify-content: space-between; border-bottom: 1px solid #e4e4e7; position: sticky; top: 0; z-index: 100;">

        <a asp-controller="Home" asp-action="Index"
           style="font-size: 1.2rem; font-weight: 700; color: #09090b; text-decoration: none; letter-spacing: -0.5px;">
            FlowDesk
        </a>

        <div style="display: flex; align-items: center; gap: 2rem;">
            <a asp-controller="Usuario" asp-action="CriarConta" class="fd-nav-link">Registrar</a>

            @if (User.Identity.IsAuthenticated)
            {
                <span style="color: #71717a; font-size: 14px;">Olá, @User.Identity.Name</span>
                <a asp-controller="Usuario" asp-action="Sair" class="fd-nav-link">Sair</a>
            }
            else
            {
                <a asp-controller="Usuario" asp-action="Login" class="fd-nav-btn">Entrar</a>
            }
        </div>

    </header>
    <div class="container">
        <main role="main" class="pb-3">
            @RenderBody()
        </main>
    </div>

    <footer class="border-top footer text-muted">
        <div class="container" style="text-align: center;">
            &copy; 2026 - FlowDesk - Criação e gestão de tickets corporativos
        </div>
    </footer>
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
